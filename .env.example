# Copiar a .env.local y ajustar. No commitear secretos.
# https://nextjs.org/docs/app/guides/environment-variables

# API REST (incluye prefijo /api)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Origen del backend para WebSocket (Socket.io no usa el rewrite de Next).
# Opcional: si no se define, se deriva del origin de NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_BACKEND_WS_ORIGIN=http://localhost:3001
# Alternativa: NEXT_PUBLIC_WS_ORIGIN (mismo efecto)
